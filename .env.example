# ── Base de datos ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<usuario>:<password>@cluster.mongodb.net/
MONGO_DB=nombre_de_tu_base_de_datos
MONGO_PASSWORD=password_del_usuario

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_largo

# ── NFC / ESP32 ───────────────────────────────────────────────────────────────
ESP32_DEVICE_KEY=clave_del_dispositivo_nfc

# ── CORS (URL del frontend en Vercel) ─────────────────────────────────────────
CLIENT_URL=https://tu-app.vercel.app

# ── Correo (Nodemailer + Gmail) ───────────────────────────────────────────────
GMAIL_USER=correo@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT lo asigna Render automáticamente, no lo definas aquí
